# ============================================================
# NVide Live Platform — Environment Template
# ============================================================
# ⚠️  IMPORTANT ⚠️
# Copy this file to `.env` and fill in every placeholder.
# NEVER commit the real `.env` file to version control.
# 
# Generate secrets with:
#   JWT / BETTER_AUTH:  openssl rand -base64 32
#   CRYPTO key (32 byte): openssl rand -base64 32 | head -c 32
#   Mnemonic:           use a trusted BIP-39 wallet generator
# ============================================================

# Server
SERVER_PORT=8080
SERVER_HOST=0.0.0.0
GRACEFUL_TIMEOUT=30s

# Database — Supabase Postgres Pooler
DB_HOST=REPLACE_WITH_SUPABASE_POOLER_HOST
DB_PORT=5432
DB_USER=REPLACE_WITH_SUPABASE_POOLER_USER
DB_PASSWORD=GENERATE_STRONG_PASSWORD
DB_NAME=postgres
DB_SSLMODE=require
DB_MAX_CONN=20
DB_MIN_CONN=5

# Redis
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=10

# JWT Secret — MUST be 32+ random characters, never the default value
# Generate with: openssl rand -base64 32
JWT_SECRET=GENERATE_A_SECURE_RANDOM_SECRET_KEY_OF_AT_LEAST_32_CHARACTERS
REFRESH_TOKEN_EXPIRY=168h
JWT_EXPIRY=15m

# Bcrypt
BCRYPT_COST=12

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=1m

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Duitku Payment Gateway
DUITKU_MERCHANT_CODE=
DUITKU_API_KEY=
DUITKU_BASE_URL=https://sandbox.duitku.com/webapi
DUITKU_CALLBACK_URL=https://your-domain.com/api/v1/payment/duitku/callback
DUITKU_RETURN_URL=https://your-domain.com/payment/status

# Crypto Payment
CRYPTO_ENCRYPTION_KEY=REPLACE_WITH_EXACTLY_32_BYTE_KEY
CRYPTO_MASTER_MNEMONIC=REPLACE_WITH_REAL_BIP39_MNEMONIC

# Blockchain RPC Endpoints
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
BTC_RPC_URL=https://blockstream.info/api
USDT_RPC_URL=https://bsc-dataseed.binance.org

# Mux Streaming (video / live-stream)
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=

# Supabase Storage
SUPABASE_URL=https://REPLACE_WITH_YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_STORAGE_BUCKET=stories

# Better Auth
BETTER_AUTH_SECRET=GENERATE_32_BYTE_RANDOM_SECRET
BETTER_AUTH_URL=https://your-domain.com

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OpenAI (AI chat / monetisation)
# Get from https://platform.openai.com/settings/organization/api-keys
OPENAI_API_KEY=
